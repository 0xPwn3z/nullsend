# SecureRelay Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Required ---

# LLM API key (Groq, OpenRouter, or Anthropic key)
API_KEY=your-api-key-here

# Vault encryption password (generate a strong random string)
# Example: python -c "import secrets; print(secrets.token_urlsafe(32))"
VAULT_PASSWORD=change-me-to-a-strong-random-password

# --- Provider (pick one) ---

# Options: groq | openrouter | anthropic | ollama
PROVIDER_NAME=groq

# Model to use (provider-specific)
# Groq:       llama-3.1-8b-instant, llama-3.3-70b-versatile
# OpenRouter:  meta-llama/llama-3.1-8b-instruct:free
# Anthropic:   claude-3-5-sonnet-20241022
# Ollama:      qwen2.5:latest
PROVIDER_MODEL=llama-3.1-8b-instant
